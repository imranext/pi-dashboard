# Pi Dashboard Environment Configuration
# Copy this file to .env and customize the values

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Security
SECRET_KEY=change-me-to-a-random-secure-key-in-production

# Features
# Set to 'true' to enable system reboot button (requires appropriate permissions)
ALLOW_REBOOT=false

# Optional: Basic Authentication (future feature)
# BASIC_AUTH_USERNAME=admin
# BASIC_AUTH_PASSWORD=secure_password_here
